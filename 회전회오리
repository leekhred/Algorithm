def solution(n):
    lst_st = [[0]*n for _ in range(n)]
    move_index = [[0,1],[1,0],[-1,0],[0,-1]] #(x,y)
    num = 1
    cur_x , cur_y = 0 , 0
    # num // n 몫으로 저장
    while num <= n:
        i = 0
        for i in range(len(move_index)):
            lst_st[cur_x][cur_y] = num
            
            num += 1
            cur_x += move_index[i][0]
            cur_y += move_index[i][1]
