import sys
input = sys.stdin.readline
#내 코드랑 공통점: 순환함수를 사용하여 모든 경우의수를 트리 형태로 변형, 0제거 합치기 새값에 등록
"""코드랑 다른점:
move함수
-아예 0을 삭제하고 시작. 
-합치고 다음 값으로 이동시킬 때 반복문 사용안하고 pop하나로 딸깍 합쳐진 값은 없어지고 자동으로 빈자리 제거
-0을 넣을 때 빈자리 이용
ratate 함수
-모두 돌림으로써 상하좌우 갱신
dfs 함수
-순환함수를 전체 경우로 사용 , 반복문을 상하좌우의 경우로 사용하여 모든 경우의 수를 만듬
""" 

N = 3
board = [[2,2,2],[4,4,4], [8,8,8]]

answer = 0

def move(b):
    new = [] #이보드는 0으로 초기화를  X
    for row in b:
        tmp = [x for x in row if x]  #0을  null값으로 본거
        print(tmp)
        i = 0 
        while i < len(tmp)-1: #for i in rang(0,len(tmp))
            if tmp[i] == tmp[i+1]:
                tmp[i] *= 2
                tmp.pop(i+1)
            i += 1
        tmp += [0]*(N-len(tmp)) #빈자리만큼 오른쪽에 0새롭게 추가..새로운데?
        new.append(tmp)
    return new



def rotate(b):
    return list(map(list, zip(*b[::-1])))

def dfs(depth, b):
    global answer
    
    if depth == 5:
        answer = max(answer, max(map(max, b)))
        return
    
    for _ in range(4): #rotate를 4번 시킴으로써 상하좌우 모두 나오도록 조정
        nb = move(b) 
        dfs(depth+1, nb)  #순환함수를 사용하여 바뀐 값을 트리로 갱신 3차원으로 생각하면  트리에 z축으로 rotate를 시키면 됨
        b = rotate(b)

dfs(0, board)
print(answer)
