def partition(A, left , right):
    pivot = A[left]
    low = left +1
    high = right
    
    while (low <high):
        Ch_low = None
        Ch_high = None
        if pivot < A[low]:
            Ch_low = A[low]
        else:
            low+=1
        if pivot > A[high]:
            Ch_high = A[high]
        else:
            high-= 1
        if Ch_low is not None and Ch_high is not None:
            A[low] , A[high] = Ch_high , Ch_low

    A[left], A[high] = A[high] , A[left]
    return high

