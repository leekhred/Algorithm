#0. 원래 메시지를 리스트로 분리
#1. 메시지를 #으로 대신해서 새롭게 표현함 (이때 공백은 #무시)
#2. #으로 만든 메시지를 split으로 리스트 만듬
#3. 인덱스는 동일하기 때문에 #으로만든 메시지의 단어를 대신해서 넣어줌으로써 검사
def solution(message, spoiler_ranges):
    lst1 = message.split(" ")
    lst_message = list(message)
    for i in spoiler_ranges:
        for j in range(i[0] , i[1]+1):
            lst_message[j] = "#" if lst_message[j] != " " else lst_message[j]
    lst2 = "".join(lst_message).split(" ")
    result = 0
    for i in range(len(lst1)):
        if lst2[i] in "#":
            if lst1[i] not in lst2:
                result +=1
            lst2[i] = lst1[i]
                
    
    
    return result
