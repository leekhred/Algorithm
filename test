#2개일때 total겹치는거 해결

def dps(ch ,stack , total):
    if (stack == 0 and  total == 1) or (total == 0):
        return 1
    else:
        if stack == 0:
            result = dps("(" , stack + 1 , total-1)
        else:
            result = dps("(" , stack+1 , total -1) + dps(")" , stack- 1, total)
        
        return result
