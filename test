def search_1(graph_a, graph_b ,tmp_lst, a , b): #순환함수 search 매개변수는 graph내부의 딕셔너리
    for key  , value in graph_a.items(): #1.모든 경우 탐색
        for key2 , value2 in graph_b.items():
            if key not in tmp_lst[:-1] and key2 not in tmp_lst[:-1]:                
                if key == key2: #2. 다음 경로의 위치가 동일한가?
                    calc_tmplst(tmp_lst , key, value)
                else:
                    calc_tmplst(tmp_lst, key , value)
                    calc_tmplst(tmp_lst, key2, value2)
            
                if key == a:
                    search2(graph[key2] , tmp_lst, b)
                    return
                elif key2 == b:
                    search2(graph[key] , tmp_lst, a)
                    return
                elif key == a and key2 == b:
                    RouteLst.append(tmp_lst)
                    return
                else:
                    search1(graph[key] , graph[key2] , tmp_lst , a, b)
                    
def search2(graph_n, tmp_lst, x):
    for key , value in graph_n.items():
        if key not in tmp_lst[:-1]:
            if key == x:
                calc_tmplst(tmp_lst , key , value)
                RouteLst.append(tmp_lst)
                break
            else:
                calc_tmplst(tmp_lst , key , value)
                search2(graph[key] , tmp_lst, x)


def calc_tmplst(tmp_lst , key , value): #계산 함수
    tmp_lst.insert(0, key)
    if start == False:
        tmp_lst.append(value) #행적
        start = True
    else:
        tmp_lst[-1]+= value #값
        
        
    
    
