    global B_RouteLst
    
    
    graph = [{} for _ in range(len(fares))] # [{} , {} ,{} .... 이런 형태?]
    for st , fin , fare in range(len(fares)):
        graph[st][fin] = fare
        graph[fin][st] = fare
    A_RouteLst = []
    B_RouteLst = []
    
    
    search_A(s, graph[s] , [], a)
