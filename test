class Node:
    def __init__(self, x, y):
        self.value = [x,y]
        self.right = None
        self.left = None
        
        

def mak_tree(graph,x1,x2,level,level_x): #level은 다음 트리레벨을 의미한다
    
    node = Node(graph[level][level_x] , level+1)
    if level == 0: #말단노드의 위치가 가장 마지막인 경우
        return Node
    
    cnt = 1
        while graph[level-cnt] == False:
            cnt+=1

        for x_Value in graph[level-cnt]:  
            if x1< x_Value and node.value[0] > x_Value:
                node.left = mak_tree(graph , x1, node.value[0],level-cnt, x_Value)
            elif x2 > x_Value and node.value[0] < x_Value:
                node.right = mak_tree(graph , node.value[0], x2 ,level-cnt, x_Value)        
        return Node
        

def preorder(node):
    if not node:
        return []
    return [node.value] + preorder(node.left) + preorder(nodeinfo.index(node.value)+1)

def postorder(node):
    if not node:
        return []
    return postorder(node.left) + postorder(node.right) + [nodeinfo.index(node.value)+1]


